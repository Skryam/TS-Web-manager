generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              Int      @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String   @unique
  passwordDigest  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
